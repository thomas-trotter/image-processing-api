[run]
source = app
omit =
    */__pycache__/*
    */__init__.py
    */main.py
    */tests/*
    */test_*.py
    */conftest.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

precision = 2
show_missing = True
skip_covered = False



